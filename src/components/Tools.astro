---
import { futureTools, toolCategories } from "../data";
import Tool from "./Tool.astro";
import PageLayout from "./Layouts/PageLayout.astro";
---

<PageLayout>
  <section>
    <div class="w-full py-3">
      <hr class="border-gray-600" />

      <div class="w-full flex justify-center">
        <div class="py-10">
          <h2 class="text-gray-200 text-2xl pb-3 text-start">Tools</h2>
          <p
            class="text-gray-400 leading-[30px] monserrat tracking-wider lg:text-center xl:text-start"
          >
            I primarily work with JavaScript and TypeScript, building modern <span
              class="blue-text">web applications</span
            > using React, Vue, Next.js, and Astro. Beyond frameworks, I’ve also
            explored and used several other <span class="blue-text"
              >languages</span
            > and tools to support different parts of the development workflow.
          </p>
        </div>
      </div>

      <div class="w-full flex flex-col gap-8 mb-8">
        {
          toolCategories.map((category) => (
            <div>
              <h3 class="text-gray-300 text-xs font-mono uppercase tracking-[0.15em] mb-2">
                {category.label}
              </h3>
              <div class="flex flex-wrap gap-x-6 gap-y-1">
                {category.items.map((item) => (
                  <Tool title={item.title} icon={item.icon} />
                ))}
              </div>
            </div>
          ))
        }
      </div>

      <div class="w-full flex justify-center">
        <div
          class="w-full border-[1px] border-gray-600 rounded-2xl my-5 md:my-0 p-5"
        >
          <p class="text-gray-400 mb-3">
            {"->"} Additional technologies and tools I’m currently <span
              class="blue-text">exploring,</span
            > or aiming to learn in the future.
          </p>
          <div class="flex flex-wrap gap-x-6 gap-y-1">
            {
              futureTools.map((item) => (
                <Tool title={item.title} icon={item.icon} />
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
