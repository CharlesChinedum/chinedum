---
import { Icon } from "astro-icon/components";
export interface Props {
  title: string;
  desc: string;
  img: string;
  url: string;
  src: string;
  stack: string[];
}

const { title, desc, img, url, src, stack } = Astro.props as Props;
---

<div class="w-full">
  <div
    class="h-full flex justify-between group border border-gray-600 hover:border-brand-100 transition duration-300 ease-in-out rounded-xl p-5"
  >
    <!-- <div class="flex flex-col gap-x-3">
      <div class="h-10 w-10">
        <img
          src={img}
          alt=""
          class="h-full w-full object-cover hover:scale-105 transform transition duration-300 ease-in-out rounded-lg"
        />
      </div>

    </div> -->
    <div class="w-full flex flex-col justify-between">
      <div>
        <h2 class="text-gray-200 text-xl lg:text-lg pt-3 font-[500]">
          {title}
        </h2>
      </div>

      <div class="">
        <p class="text-gray-500 text-lg md:text-base pb-5">{desc}</p>
      </div>

      <div class="w-full flex flex-col md:flex-row md:items-center justify-between gap-3 md:gap-0">
        <div class="flex items-start flex-wrap gap-x-3 gap-y-1 mb-2">
          {
            stack?.map((item) => (
              <div class="flex items-center gap-x-1">
                <div class="w-2 h-2 bg-gray-700 rounded-full group-hover:bg-brand-100  transition-all duration-300 ease-in-out" />
                <p class="text-gray-500 text-sm lg:text-xs font-medium">
                  {item}
                </p>
              </div>
            ))
          }
        </div>
        <div class="flex justify-end gap-3">
          <div>
          {
            src != undefined ? (
              <a href={src} target="_blank">
                  <Icon
                    name="mdi:github-circle"
                    size="24"
                    class="text-gray-400 hover:text-gray-300"
                  />
              </a>
            ) : null
          }
          </div>
          <a href={url} target="_blank">
            <Icon name="mdi:link-variant" size="24" class="text-gray-400  hover:text-gray-300" />
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
