---
import PageLayout from "./Layouts/PageLayout.astro";
---

<PageLayout>
  <section class="w-full" id="about">
    <div class="w-full">
      <hr class="border-gray-600" />
      <div class="flex flex-col w-full items-center">
        <div class="py-10 w-full flex flex-col items-center">
          <p
            class="text-gray-400 leading-[30px] monserrat tracking-wider lg:text-center xl:text-start"
          >
            I'm a fullstack engineer with a frontend focus, building fast,
            accessible, and reliable web applications with React, Next.js, Vue,
            Astro, and TypeScript. I've shipped products across <span
              class="blue-text">real estate</span
            >, <span class="blue-text">fintech</span>, and <span class="blue-text"
              >critical infrastructure</span
            > — turning complex requirements into interfaces that stay clean,
            intuitive, and dependable in production. Whether it's launching a new
            product or scaling an existing platform, I care about the details that
            make software feel effortless to use.
          </p>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
