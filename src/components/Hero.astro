---
import { Image } from "astro:assets";
import avatar from "../images/avatar1.jpg";
import PageLayout from "./Layouts/PageLayout.astro";
import { socials } from "../data";
import SocialIcon from "./General/SocialIcon.astro";
---

<PageLayout>
  <section class="w-full my-16 md:my-20">
    <div class="flex flex-col sm:flex-row sm:items-center gap-6 sm:gap-8">
      <div class="shrink-0">
        <div class="w-28 h-28">
          <Image
            src={avatar}
            alt="Chinedum U."
            width={224}
            class="w-full h-full rounded-lg object-cover"
          />
        </div>
      </div>

      <div class="flex flex-col gap-4 w-full">
        <div
          class="inline-flex items-center gap-2 self-start rounded-full border border-gray-700 px-3 py-1"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75 animate-ping"
            ></span>
            <span
              class="relative inline-flex h-2 w-2 rounded-full bg-green-500"
            ></span>
          </span>
          <span class="text-xs font-mono text-gray-300"
            >Available for new opportunities</span
          >
        </div>

        <div class="space-y-1">
          <h1 class="text-gray-100 text-2xl font-mono">Chinedum U.</h1>
          <p class="font-mono text-brand-100 text-base">
            Fullstack Software Engineer
          </p>
        </div>

        <p class="text-gray-400 text-sm leading-6 monserrat max-w-xl">
          I build fast, accessible web applications — from real estate platforms
          to critical-infrastructure tools — with React, Next.js, Vue, and
          Astro.
        </p>

        <div class="flex flex-wrap items-center gap-3">
          <a
            href="/#contact"
            class="rounded-lg bg-brand-100 px-4 py-2 text-sm font-mono text-white transition hover:opacity-90"
          >
            Get in touch
          </a>
          <a
            href="/resume.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-lg border border-gray-600 px-4 py-2 text-sm font-mono text-gray-300 transition hover:border-brand-100 hover:text-gray-100"
          >
            Résumé
          </a>
        </div>

        <div class="flex gap-x-3 pt-1">
          {
            socials.map((social) => (
              <SocialIcon
                url={social.url}
                icon={social.icon}
                title={social.title}
              />
            ))
          }
        </div>
      </div>
    </div>
  </section>
</PageLayout>
