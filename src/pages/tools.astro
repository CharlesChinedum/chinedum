---
import Layout from "../Layouts/Layout.astro";
import "../styles/global.css";

import BlogNavbar from "../components/BlogNavbar.astro";
import PageLayout from "../components/Layouts/PageLayout.astro";
import { futureTools, toolCategories } from "../data";
import Tool from "../components/Tool.astro";
---

<Layout
  title="Tools & Technologies — Chinedum U."
  description="The languages, frameworks, and tools Chinedum U. works with day to day, plus technologies currently being explored."
>
  <PageLayout>
    <section>
      <BlogNavbar />
      <div class="flex justify-center items-start my-20">
        <div class="container text-gray-400 lg:px-5 pb-7">
          <div class="mb-10">
            <h2 class="text-gray-200 text-2xl md:text-3xl font-[600]">Tools</h2>
            <p
              class="text-gray-400 leading-[30px] monserrat tracking-wider mt-2"
            >
              I primarily work with JavaScript and TypeScript, building modern <span
                class="text-brand-100">web applications</span
              > using React, Vue, Next.js, and Astro. Beyond frameworks, I’ve also
              explored and used several other <span class="text-brand-100"
                >languages</span
              > and tools to support different parts of the development workflow.
            </p>
          </div>

          <div class="flex flex-col gap-8">
            {
              toolCategories.map((category) => (
                <div>
                  <h3 class="text-gray-300 text-xs font-mono uppercase tracking-[0.15em] mb-2">
                    {category.label}
                  </h3>
                  <div class="flex flex-wrap gap-x-6 gap-y-1">
                    {category.items.map((item) => (
                      <Tool title={item.title} icon={item.icon} />
                    ))}
                  </div>
                </div>
              ))
            }
          </div>

          <div class="w-full flex justify-center mt-10">
            <div class="w-full border-[1px] border-gray-600 rounded-2xl p-5">
              <p class="text-gray-400 mb-3">
                {"->"} Other things I am currently learning, intend to take a deeper
                dive into or get started with at some point in the future.
              </p>
              <div class="flex flex-wrap gap-x-6 gap-y-1">
                {
                  futureTools.map((item) => (
                    <Tool title={item.title} icon={item.icon} />
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </PageLayout>
</Layout>
